# ── AI Provider ──────────────────────────────────────────────
# Ambil gratis di https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy...

# ── NextAuth v5 (Google OAuth) ──────────────────────────────
# Daftar di https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://[domain-mu].vercel.app/api/auth/callback/google
AUTH_SECRET=generate pake: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_GOOGLE_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
AUTH_URL=https://[domain-mu].vercel.app
# Local dev: AUTH_URL=http://localhost:3000

# ── Settings Encryption ──────────────────────────────────────
# Wajib di-set untuk mengenkripsi API key user di database.
# Generate pake: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SETTINGS_ENCRYPTION_KEY=base64_32_byte_key_here

# ── Turso (SQLite hosted — WAJIB untuk Vercel) ──────────────
# Daftar gratis di https://turso.tech
#   turso db create ideforge
#   turso db show ideforge --url          → ambil URL
#   turso db tokens create ideforge       → ambil token
TURSO_DATABASE_URL=libsql://...
TURSO_AUTH_TOKEN=eyJ...

# ── Dev Login (testing tanpa Google OAuth) ──────────────────
#   NODE_ENV=development atau set DEV_SECRET akan mengaktifkan login lewat kode
#   Gunakan di halaman Login → Dev Login
DEV_SECRET=dev-login-2024
DEV_EMAIL=dev@ideforge.app
DEV_NAME="Dev User"
