# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (private — never commit actual secrets)
.env
.env.local
.env.development
.env.production
# allow example files to be committed
!.env.example
!.env.local.example

# local sqlite database
*.sqlite
*.sqlite-wal
*.sqlite-shm
auth
auth-wal

# agent session memory
.memory/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
